# Rename this file to .env for local testing.
# For production, add these as Environment Variables in your Vercel project settings.

# Get from @BotFather on Telegram
BOT_TOKEN=123456789:ABCDEF_your_bot_token_here

# Get from https://console.groq.com/keys (free, no credit card)
GROQ_API_KEY=gsk_your_groq_key_here

# Optional - change the model if you want
# Options: llama-3.1-8b-instant (fast, default), llama-3.3-70b-versatile (smarter, slower)
GROQ_MODEL=llama-3.1-8b-instant
